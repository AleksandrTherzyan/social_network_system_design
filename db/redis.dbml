Project redis {
  database_type: 'Redis'
  Note: 'Используется как модель чтения постов, и хранения счетчика лайков.'
}

Enum redis_moderation_status {
  moderation
  published
  rejected
}

Enum feed_type {
  traveler
  subscriptions
}

Table post_like_counters {
  post_id bigint [pk]
  like_count bigint [not null]
  updated_at timestamp [not null]
}

Table post_read_models {
  post_id bigint [pk]
  author_id bigint [not null]
  author_name varchar(128) [not null]
  place_id bigint [not null]
  place_name varchar(64) [not null]
  place_country varchar(64) [not null]
  title varchar(64)
  description varchar(256) [not null]
  status redis_moderation_status [not null]
  photos json
  like_count bigint [not null]
  comments_count bigint [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table traveler_feed_read_models {
  cache_key varchar(128) [pk]
  traveler_id bigint [not null]
  type feed_type [not null]
  post_ids json [not null]
  next_cursor bigint
  updated_at timestamp [not null]

  Note: 'cache_key пример: traveler_feed:{traveler_id}:{type}.'
}

Table place_posts_read_models {
  cache_key varchar(128) [pk]
  place_id bigint [not null]
  post_ids json [not null]
  next_cursor bigint
  updated_at timestamp [not null]

  Note: 'cache_key пример: place_posts:{place_id}'
}
